{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "variables": {
    "NIXPACKS_NODE_VERSION": "20"
  },
  "deploy": {
    "startCommand": "npx prisma db push && npm run start",
    "restartPolicyType": "ON_FAILURE",
    "healthcheckPath": "/"
  }
}
